{
  // Cloudflare 배포 설정 — docs/ 정적 서빙 + 방문자 카운터 Worker(/api/hit)
  "name": "hbmonster",
  "compatibility_date": "2026-06-16",
  "main": "worker.js",
  "assets": {
    "directory": "docs",
    "binding": "ASSETS"
  },
  // 금일 방문자수 카운터 저장소(KV). binding 이름 VISITS는 worker.js와 일치해야 함.
  "kv_namespaces": [
    { "binding": "VISITS", "id": "54e202310f484d48833545fb61dc91be" }
  ]
}
